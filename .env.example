# AttestRail environment variables
#
# This file documents all non-Hardhat-vars secrets and configuration.
# Hardhat secrets (MNEMONIC, INFURA_API_KEY, ETHERSCAN_API_KEY) are managed
# via `npx hardhat vars setup` per the Zama template; do not put them here.
#
# Copy to `.env` and fill in. Never commit `.env`.

# --- Mock Attester Service (attester/) ---
# 32-byte hex private key (without 0x prefix is fine; either works).
# This key signs EIP-712 attestations. Its address must be approved
# in AttesterRegistry via scripts/deploy.ts.
ATTESTER_PRIVATE_KEY=

# Port the attester service listens on locally.
ATTESTER_PORT=4001

# --- Frontend dApp (app/) ---
# Sepolia RPC endpoint with FHEVM coprocessor support.
VITE_RPC_URL=https://sepolia.infura.io/v3/REPLACE_WITH_INFURA_KEY

# URL where the mock attester service is reachable from the browser.
VITE_ATTESTER_URL=http://localhost:4001

# --- Issuer / demo defaults (used by scripts/seed.ts) ---
# Address that owns the default policy and receives the initial mock
# RWA token mint. Defaults to deployer if unset.
ISSUER_ADDRESS=

# Demo encrypted thresholds for the default policy. Plain numbers; the
# script will encrypt them.
DEFAULT_MAX_EXPOSURE=100000
DEFAULT_ISSUER_EXPOSURE_CAP=10000000

# Initial mock RWA token mint to the issuer.
INITIAL_MINT=1000000

# Optional: prepopulate the encrypted aggregate with one or two
# pre-approved checks during seed (default off).
SEED_PREPOPULATE_AGGREGATE=false
